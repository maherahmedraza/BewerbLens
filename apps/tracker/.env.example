# Tracker / orchestrator environment
# Most Gmail credentials are stored per user in user_profiles.gmail_credentials.
# Keep the legacy JSON fallbacks empty unless you are running a one-off local bootstrap.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_INPUT_COST_PER_MILLION=0.10
GEMINI_OUTPUT_COST_PER_MILLION=0.40

ENCRYPTION_SECRET=your-32-byte-app-secret
ENCRYPTION_KEY=legacy-fernet-key-optional

USER_EMAIL=your-email@gmail.com
GMAIL_DAILY_QUOTA_UNITS=1000000000
GMAIL_CREDENTIALS_JSON=
GMAIL_TOKEN_JSON=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=

BATCH_SIZE=50
MIN_CONFIDENCE=0.55
BACKFILL_START_DATE=2025-10-01
PROMPT_BODY_MAX_CHARS=400
CLASSIFIER_MAX_BATCH_TOKENS=3000
