# BewerbLens shared local environment
# Copy to .env and fill in the real values.

# ── Dashboard public runtime ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
ORCHESTRATOR_URL=http://localhost:8000

# ── Dashboard server-only routes ──────────────────────────────────
ORCHESTRATOR_API_KEY=shared-secret-for-dashboard-to-orchestrator-calls
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
TELEGRAM_BOT_USERNAME=your_telegram_bot_username
TELEGRAM_LINK_SECRET=shared-secret-used-by-your-telegram-bot

# ── Shared backend credentials ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
ENCRYPTION_SECRET=your-32-byte-app-secret
ENCRYPTION_KEY=legacy-fernet-key-optional

# ── Gmail / tracker behavior ──────────────────────────────────────
USER_EMAIL=your-email@gmail.com
GMAIL_DAILY_QUOTA_UNITS=1000000000
# Optional legacy bootstrap fallback for non-user-scoped local runs only
GMAIL_CREDENTIALS_JSON=
GMAIL_TOKEN_JSON=

# ── Telegram notifications ────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=

# ── Pipeline / classifier tuning ──────────────────────────────────
BATCH_SIZE=50
MIN_CONFIDENCE=0.55
BACKFILL_START_DATE=2025-10-01
PROMPT_BODY_MAX_CHARS=400
CLASSIFIER_MAX_BATCH_TOKENS=3000
GEMINI_INPUT_COST_PER_MILLION=0.10
GEMINI_OUTPUT_COST_PER_MILLION=0.40
FOLLOW_UP_REMINDER_DAYS=14
FOLLOW_UP_REMINDER_REPEAT_DAYS=7
