# ╔══════════════════════════════════════════════════════════════╗
# ║  BewerbLens — Central Environment Configuration             ║
# ║  ALL secrets live in this single file.                      ║
# ║  NEVER commit the real .env — only .env.example.            ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Copy this file as .env and fill in the real values:
#   cp .env.example .env

# ── Dashboard (Next.js) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8001

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── Supabase (Service Role — backend only) ───────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── Telegram Notifications ───────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Pipeline Settings ────────────────────────────────────────
BATCH_SIZE=10
MIN_CONFIDENCE=0.55
BACKFILL_START_DATE=2025-10-01

# ── Scheduler ────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULE_INTERVAL_HOURS=4.0

# ── Gmail API ─────────────────────────────────────────────────
USER_EMAIL=your_email@gmail.com
# Use full JSON string from Google Cloud Console (single-line, wrapped in quotes)
GMAIL_CREDENTIALS_JSON='{"installed":{...}}'
# Generated after running the OAuth flow (single-line, wrapped in quotes)
GMAIL_TOKEN_JSON='{"token":...}'
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3000/auth/gmail/callback
ENCRYPTION_KEY=your_fernet_encryption_key
